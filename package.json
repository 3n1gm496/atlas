{
  "name": "atlas-cartografia",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:browser-audit": "node scripts/browser-audit.mjs",
    "bootstrap:local": "bash scripts/bootstrap-local.sh",
    "prisma:generate": "prisma generate",
    "prisma:doctor": "node scripts/prisma-doctor.mjs",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && npm run prisma:seed"
  },
  "dependencies": {
    "@prisma/client": "^5.19.1",
    "@types/leaflet": "^1.9.21",
    "bcryptjs": "^3.0.3",
    "leaflet": "^1.9.4",
    "next": "^16.3.0-canary.23",
    "next-auth": "^4.24.13",
    "next-intl": "^4.12.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.46.0",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "20.14.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "10.4.19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.3.0-canary.23",
    "postcss": "8.5.15",
    "prisma": "^5.19.1",
    "tailwindcss": "3.4.7",
    "tsx": "^4.16.3",
    "typescript": "5.5.4",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "postcss": "8.5.15",
    "next": {
      "postcss": "8.5.15"
    }
